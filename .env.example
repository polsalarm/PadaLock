# PadaLock testnet env. Copy to apps/web/.env.local

# Deployed PadaLock contract on Stellar testnet (USDC-bound instance)
NEXT_PUBLIC_PADALOCK_CONTRACT_ID=

# XLM-bound PadaLock instance (native SAC) — enables XLM padalas
NEXT_PUBLIC_PADALOCK_XLM_CONTRACT_ID=

# USDC SAC contract id on testnet (wrap your own testnet USDC asset via stellar CLI)
NEXT_PUBLIC_USDC_SAC_TESTNET=

# XLM native Stellar Asset Contract id on testnet
NEXT_PUBLIC_XLM_SAC_TESTNET=
